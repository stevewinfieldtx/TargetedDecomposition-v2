# ── Server ──────────────────────────────────────────────
PORT=8500

# ── Internal service URLs ──────────────────────────────
# TDE atom engine
TDE_INTERNAL_URL=http://localhost:8400

# TrueArtifact craft engine
TRUEARTIFACT_INTERNAL_URL=http://localhost:8600

# ── Authentication ─────────────────────────────────────
# Shared secret that consuming apps (Hydrate, Recruit, Target) send as x-api-key
API_SECRET_KEY=

# Bearer token sent to TrueArtifact for internal auth
TRUEARTIFACT_AUTH_TOKEN=

# ── Cache ──────────────────────────────────────────────
# PostgreSQL connection string for persistent cache (optional — falls back to in-memory)
CACHE_DATABASE_URL=
