# TrueArtifact — Stateless Craft/Rendering Engine
# Copy to .env and fill in values

# Server port (Railway sets PORT automatically)
PORT=8600

# OpenRouter — primary LLM provider
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Cerebras — fast inference provider (optional, falls back to OpenRouter)
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=llama-3.3-70b

# Model selection
ANALYSIS_MODEL=qwen/qwen-2.5-72b-instruct
CONTENT_MODEL=meta-llama/llama-3.1-70b-instruct

# Internal auth token — must match Orchestrator's outbound token
INTERNAL_AUTH_TOKEN=
