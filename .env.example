# ── TDE — Targeted Decomposition Engine ──────────────────────────────────────
# Copy to .env and fill in your keys.

# Server
PORT=8400

# OpenRouter (LLM + embeddings, used for real-time work)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Anthropic direct (Batch API for non-realtime research — 50% discount)
# When set, Deep Fill and other batch-eligible jobs route here.
# Leave empty to use existing OpenRouter behavior for everything.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_BATCH_MODEL=claude-sonnet-4-6

# Models
ANALYSIS_MODEL=qwen/qwen-2.5-72b-instruct
CONTENT_MODEL=meta-llama/llama-3.1-70b-instruct
EMBEDDING_MODEL=sentence-transformers/multi-qa-mpnet-base-dot-v1

# YouTube
YOUTUBE_API_KEY=

# Groq Whisper (audio transcription — YouTube fallback + local audio files)
GROQ_API_KEY=

# PostgreSQL (persistent — set this on Railway)
DATABASE_URL=

# Qdrant (vector search)
QDRANT_URL=
QDRANT_API_KEY=
EMBEDDING_DIMENSION=768

# API Security
API_SECRET_KEY=

# Storage
DATA_DIR=./data
